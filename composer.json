{
    "name": "beardcoder/mens-circle",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.5",
        "filament/filament": "^5.6.0",
        "filament/spatie-laravel-media-library-plugin": "^5.6.0",
        "filament/spatie-laravel-settings-plugin": "^5.6.0",
        "laravel-notification-channels/pushover": "^5.0",
        "laravel/framework": "^13.6",
        "laravel/mcp": "^0.7.0",
        "laravel/octane": "^2.17",
        "laravel/passport": "^13.0",
        "laravel/socialite": "^5.26.0",
        "laravel/tinker": "^3.0",
        "nunomaduro/essentials": "^1.2",
        "sentry/sentry-laravel": "^4.24.0",
        "seven.io/api": "^8.1.1",
        "spatie/laravel-medialibrary": "^11.21.1",
        "spatie/laravel-navigation": "^1.3",
        "spatie/laravel-responsecache": "^8.3.0",
        "spatie/laravel-settings": "^3.7",
        "spatie/laravel-sitemap": "^8.1.0",
        "spatie/laravel-sluggable": "^4.0.2",
        "spatie/schema-org": "^4.0",
        "voku/html-min": "^5.0.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2.7",
        "barryvdh/laravel-ide-helper": "^3.6.1",
        "fakerphp/faker": "^1.24.1",
        "filament/upgrade": "^5.6.0",
        "kitloong/laravel-migrations-generator": "^7.3",
        "laravel/boost": "^2.4.8",
        "laravel/pail": "^1.2.6",
        "laravel/sail": "^1.55"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "scripts": {
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade",
            "@composer outdated --direct"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#fbbf24\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"php artisan schedule:work\" \"bun run dev\" --names=server,queue,logs,scheduler,vite --kill-others"
        ],
        "format": [
            "mago format"
        ],
        "format:check": [
            "mago format --dry-run"
        ],
        "lint": [
            "mago lint"
        ],
        "lint:fix": [
            "mago lint --fix"
        ],
        "analyze": [
            "mago analyze"
        ],
        "qa": [
            "@format:check",
            "@lint",
            "@analyze"
        ],
        "qa:fix": [
            "@format",
            "@lint:fix"
        ],
        "review": [
            "@qa"
        ],
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ]
    }
}
