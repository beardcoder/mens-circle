{
  "permissions": {
    "allow": [
      "mcp__laravel-boost__search-docs",
      "mcp__laravel-boost__application-info",
      "mcp__mens-circle-ai__site_overview"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ],
  "enabledPlugins": {
    "fullstack-dev-skills@fullstack-dev-skills": true
  },
  "mcpServers": {
    "laravel-boost": {
      "command": "ddev",
      "args": [
        "artisan",
        "boost:mcp"
      ]
    }
  }
}
