{
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "laravel-boost"
  ],
  "enabledPlugins": {
    "fullstack-dev-skills@fullstack-dev-skills": true
  },
  "mcpServers": {
    "laravel-boost": {
      "command": "ddev",
      "args": [
        "artisan",
        "boost:mcp"
      ]
    }
  },
  "permissions": {
    "allow": [
      "mcp__laravel-boost__search-docs"
    ]
  }
}
