{
  "extends": ["stylelint-config-standard", "stylelint-config-recess-order"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "theme",
          "source",
          "utility",
          "variant",
          "custom-variant",
          "apply",
          "tailwind",
          "config",
          "plugin",
          "reference"
        ]
      }
    ],
    "nesting-selector-no-missing-scoping-root": null,
    "import-notation": null,
    "no-descending-specificity": null
  }
}
