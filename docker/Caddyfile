{
	{$CADDY_GLOBAL_OPTIONS}

	admin {$CADDY_SERVER_ADMIN_HOST}:{$CADDY_SERVER_ADMIN_PORT}

	frankenphp {
		worker {
			file "{$APP_PUBLIC_PATH}/frankenphp-worker.php"
			{$CADDY_SERVER_WORKER_DIRECTIVE}
			{$CADDY_SERVER_WATCH_DIRECTIVES}
		}
	}
}

{$CADDY_EXTRA_CONFIG}

{$CADDY_SERVER_SERVER_NAME} {
	log {
		level {$CADDY_SERVER_LOG_LEVEL}

		format filter {
			wrap {$CADDY_SERVER_LOGGER}
			fields {
				uri query {
					replace authorization REDACTED
				}
			}
		}
	}

	route {
		root * "{$APP_PUBLIC_PATH}"
		encode zstd br gzip

		# Fingerprinted/built assets never change — cache forever.
		@immutable path /build/* /_assets/*
		header @immutable Cache-Control "public, max-age=31536000, immutable"

		# Fonts rarely change — cache for a year.
		@fonts path /fonts/*
		header @fonts Cache-Control "public, max-age=31536000, immutable"

		# Images + favicons may be updated occasionally — 7 days.
		@images path /images/* /favicon*.png /favicon.svg /favicon.ico /logo*.svg /logo*.png /apple-touch-icon*.png
		header @images Cache-Control "public, max-age=604800"

		# Static manifests/robots — shorter TTL for fast iteration.
		@meta path /robots.txt /sitemap.xml /manifest.json /browserconfig.xml /admin-manifest.json
		header @meta Cache-Control "public, max-age=3600"

		# Security headers applied to every response (HTML + assets).
		header {
			X-Content-Type-Options nosniff
			Referrer-Policy strict-origin-when-cross-origin
			X-Frame-Options SAMEORIGIN
			-Server
		}

		{$CADDY_SERVER_EXTRA_DIRECTIVES}

		php_server {
			index frankenphp-worker.php
			try_files {path} frankenphp-worker.php
			resolve_root_symlink
		}
	}
}
