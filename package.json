{
  "name": "mens-circle",
  "$schema": "https://www.schemastore.org/package.json",
  "dependencies": {
    "@beardcoder/lume": "0.9.0",
    "@tailwindcss/vite": "^4.3.1",
    "leaflet": "^1.9.4",
    "motion": "^12.40.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "laravel-vite-plugin": "^3.1.0",
    "prettier": "^3.9.1",
    "prettier-plugin-blade": "^3.1.6",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-use-logical": "^2.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.1.0"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "format": "prettier --write \"resources/**/*.{ts,js,css,blade.php}\" && bun run stylelint -- --fix",
    "format:check": "prettier --check \"resources/**/*.{ts,js,css,blade.php}\"",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "stylelint": "stylelint \"resources/**/*.css\"",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
