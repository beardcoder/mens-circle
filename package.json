{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "mens-circle",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"resources/**/*.{ts,js,css,blade.php}\" && bun run stylelint -- --fix",
        "format:check": "prettier --check \"resources/**/*.{ts,js,css,blade.php}\"",
        "lint": "eslint . --fix",
        "lint:check": "eslint .",
        "stylelint": "stylelint \"resources/**/*.css\"",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/css": "^1.2.0",
        "@eslint/js": "^10.0.1",
        "@fontsource-variable/dm-sans": "^5.2.8",
        "@fontsource-variable/playfair-display": "^5.2.8",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/leaflet": "^1.9.21",
        "@types/node": "^25.6.2",
        "concurrently": "^9.2.1",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.6.0",
        "laravel-vite-plugin": "^3.1.0",
        "prettier": "^3.8.3",
        "prettier-plugin-blade": "^3.1.6",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "stylelint": "^17.11.0",
        "stylelint-config-recess-order": "^7.7.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-order": "^8.1.1",
        "stylelint-use-logical": "^2.1.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.11"
    },
    "packageManager": "bun@1.3.13",
    "dependencies": {
        "@beardcoder/stitch-js": "^1.0.4",
        "leaflet": "^1.9.4",
        "swup": "^4.9.0"
    }
}
